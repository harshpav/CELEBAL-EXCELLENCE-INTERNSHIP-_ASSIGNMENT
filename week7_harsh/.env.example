# ============================================================
# RAG System — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ----- LLM Provider -----
# Required for OpenAI embeddings and generation
OPENAI_API_KEY=sk-...

# Model names (optional — defaults shown)
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_DIMENSIONS=1536

# ----- Embedding Backend -----
# "openai" or "local"
# "local" uses sentence-transformers (no API key needed)
EMBEDDING_BACKEND=openai

# Local model name (used when EMBEDDING_BACKEND=local)
LOCAL_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# ----- Vector Store -----
# Path where ChromaDB persists data
CHROMA_PERSIST_DIR=./data/chroma

# ChromaDB collection name
CHROMA_COLLECTION=rag_documents

# ----- Chunking -----
CHUNK_SIZE=800
CHUNK_OVERLAP=100

# ----- Retrieval -----
# Number of chunks to retrieve before reranking
RETRIEVAL_TOP_K=20

# Number of chunks to pass to the LLM after reranking
RERANK_TOP_N=5

# BM25 weight in RRF fusion (vector weight = 1 - BM25_WEIGHT)
BM25_WEIGHT=0.4

# ----- Generation -----
# Maximum tokens for the LLM answer
MAX_ANSWER_TOKENS=1024

# Temperature for LLM generation (0 = deterministic)
LLM_TEMPERATURE=0.0

# ----- Logging -----
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
